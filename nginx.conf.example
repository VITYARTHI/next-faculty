map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream next_faculty {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;

    server_name faculty.vityarthi.com;

    access_log /var/log/nginx/faculty.vityarthi.com.access.log;
    error_log  /var/log/nginx/faculty.vityarthi.com.error.log;

    location / {
        proxy_pass http://next_faculty;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Required for streaming responses from the Next.js App Router.
        proxy_buffering off;
    }
}
