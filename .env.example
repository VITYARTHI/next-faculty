# Server-side only. Used by Next.js rewrites in next.config.ts to proxy
# /api/v1/* to the backend. Never expose this to the browser — frontend
# code always calls the same-origin /api/v1/* paths.
BACKEND_URL=http://localhost:8000

# Cloudflare Turnstile site key. Public — exposed to the browser. Required
# for the login page to render the bot-protection widget. Get a site key at
# https://dash.cloudflare.com/?to=/:account/turnstile.
# For local development use the Cloudflare-provided test key
# `1x00000000000000000000AA` (always passes).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
